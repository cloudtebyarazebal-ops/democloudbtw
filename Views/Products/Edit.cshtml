@* Форма создания (Id=0) или редактирования существующего товара *@
@model KodShopWeb.ViewModels.ProductFormViewModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Добавление товара" : "Редактирование товара";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <h2>@ViewData["Title"]</h2>
    <a class="btn btn-secondary" href="@Url.Action("Index")">Назад</a>
</section>

<!-- POST-форма с загрузкой изображения (multipart/form-data) -->
<form asp-action="Save" method="post" enctype="multipart/form-data" class="edit-form">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CurrentImagePath" />

    @* Поле ID только при редактировании (только для чтения) *@
    @if (Model.Id > 0)
    {
        <div class="form-group">
            <label>ID</label>
            <input class="form-control" value="@Model.Id" readonly />
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="alert alert-error"></div>

    <div class="form-group">
        <label asp-for="Article"></label>
        <input asp-for="Article" class="form-control" />
        <span asp-validation-for="Article" class="field-error"></span>
    </div>
    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="field-error"></span>
    </div>
    <div class="form-group">
        <label asp-for="CategoryId">Категория</label>
        <select asp-for="CategoryId" class="form-control" asp-items="@(new SelectList(Model.Categories, "Id", "Name"))"></select>
    </div>
    <div class="form-group">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
    </div>
    <div class="form-group">
        <label asp-for="ManufacturerId">Производитель</label>
        <select asp-for="ManufacturerId" class="form-control" asp-items="@(new SelectList(Model.Manufacturers, "Id", "Name"))"></select>
    </div>
    <div class="form-group">
        <label asp-for="SupplierId">Поставщик</label>
        <select asp-for="SupplierId" class="form-control" asp-items="@(new SelectList(Model.Suppliers, "Id", "Name"))"></select>
    </div>
    <div class="form-group">
        <label asp-for="Price"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="field-error"></span>
    </div>
    <div class="form-group">
        <label asp-for="Unit"></label>
        <input asp-for="Unit" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="QuantityOnStock"></label>
        <input asp-for="QuantityOnStock" class="form-control" />
        <span asp-validation-for="QuantityOnStock" class="field-error"></span>
    </div>
    <div class="form-group">
        <label asp-for="Discount"></label>
        <input asp-for="Discount" class="form-control" />
        <span asp-validation-for="Discount" class="field-error"></span>
    </div>
    <!-- Загрузка фото и предпросмотр текущего изображения -->
    <div class="form-group">
        <label asp-for="ImageFile">Фото</label>
        <input asp-for="ImageFile" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
        <img src="@(string.IsNullOrWhiteSpace(Model.CurrentImagePath) ? "/images/picture.png" : Model.CurrentImagePath)" alt="Предпросмотр" class="product-preview" />
    </div>

    <button type="submit" class="btn btn-accent">Сохранить</button>
</form>
