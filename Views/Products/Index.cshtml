@* Страница списка товаров с серверной фильтрацией, сортировкой и CRUD-действиями *@
@model KodShopWeb.ViewModels.ProductsIndexViewModel
@using KodShopWeb.Models
@{
    ViewData["Title"] = "Товары";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string SortFieldValue(ProductSortField field) => field switch
    {
        ProductSortField.Quantity => "quantity",
        ProductSortField.Discount => "discount",
        _ => "price"
    };
    var currentSortField = SortFieldValue(Model.SortField);
    var currentSortDirection = Model.SortDirection == SortDirection.Desc ? "desc" : "asc";
}

<section class="page-header">
    <h2>Список товаров</h2>
    @if (Model.CanEditProducts)
    {
        <a class="btn btn-accent" href="@Url.Action("Create")">Добавить товар</a>
    }
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

@if (Model.CanUseAdvancedTools)
{
    <form id="productsFilterForm" method="get" asp-action="Index" class="toolbar">
        <input id="searchInput" name="search" class="form-control" placeholder="Поиск..." value="@Model.Search" />
        <select id="discountFilter" name="discountFilter" class="form-control">
            @foreach (var range in Model.DiscountFilterOptions)
            {
                if (range.Key == Model.DiscountFilterKey)
                {
                    <option value="@range.Key" selected="selected">@range.Label</option>
                }
                else
                {
                    <option value="@range.Key">@range.Label</option>
                }
            }
        </select>
        <select id="sortField" name="sortField" class="form-control">
            @if (Model.IsProfileVariant)
            {
                <option value="price" selected="@(currentSortField == "price" ? "selected" : null)">Цена</option>
                <option value="quantity" selected="@(currentSortField == "quantity" ? "selected" : null)">Количество на складе</option>
            }
            else
            {
                <option value="quantity" selected="@(currentSortField == "quantity" ? "selected" : null)">Количество на складе</option>
                <option value="price" selected="@(currentSortField == "price" ? "selected" : null)">Цена</option>
                <option value="discount" selected="@(currentSortField == "discount" ? "selected" : null)">Скидка</option>
            }
        </select>
        <select id="sortDirection" name="sortDirection" class="form-control">
            <option value="asc" selected="@(currentSortDirection == "asc" ? "selected" : null)">По возрастанию</option>
            <option value="desc" selected="@(currentSortDirection == "desc" ? "selected" : null)">По убыванию</option>
        </select>
    </form>
}

<div class="product-table-wrapper">
    <table class="product-table" id="productsTable">
        <thead>
            <tr>
                <th>Фото</th>
                <th>Наименование</th>
                <th>Категория</th>
                <th>Описание</th>
                <th>Производитель</th>
                <th>Поставщик</th>
                <th>Цена</th>
                <th>Ед.</th>
                <th>На складе</th>
                <th>Скидка</th>
                @if (Model.CanEditProducts)
                {
                    <th></th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model.Products)
            {
                <tr class="product-row @product.RowClass" style="background-color:@product.RowStyle">
                    <td><img src="@product.ImageUrl" alt="@product.Name" class="product-thumb" /></td>
                    <td>@product.Name</td>
                    <td>@product.Category</td>
                    <td class="description-cell">@product.Description</td>
                    <td>@product.Manufacturer</td>
                    <td>@product.Supplier</td>
                    <td>
                        @if (product.HasDiscount)
                        {
                            <span class="price-old">@product.Price.ToString("0.00") ₽</span>
                            <span class="price-new">@product.FinalPrice.ToString("0.00") ₽</span>
                        }
                        else
                        {
                            <span>@product.Price.ToString("0.00") ₽</span>
                        }
                    </td>
                    <td>@product.Unit</td>
                    <td>@product.QuantityOnStock</td>
                    <td>@product.Discount.ToString("0.##")%</td>
                    @if (Model.CanEditProducts)
                    {
                        <td class="actions-cell">
                            <a class="btn btn-small" href="@Url.Action("Edit", new { id = product.Id })">Изм.</a>
                            <form asp-action="Delete" method="post" class="inline-form" onsubmit="return confirm('Удалить товар?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@product.Id" />
                                <input type="hidden" name="search" value="@Model.Search" />
                                <input type="hidden" name="discountFilter" value="@Model.DiscountFilterKey" />
                                <input type="hidden" name="sortField" value="@currentSortField" />
                                <input type="hidden" name="sortDirection" value="@currentSortDirection" />
                                <button type="submit" class="btn btn-small btn-danger">Удал.</button>
                            </form>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    @if (Model.CanUseAdvancedTools)
    {
        <script src="~/js/products.js"></script>
    }
}
